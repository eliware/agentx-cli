{
  "model": "gpt-5.4-mini",
  "input": [
    {
      "role": "developer",
      "content": [
        {
          "type": "input_text",
          "text": "<insert AGENTS.md chain>"
        }
      ]
    },
    {
      "role": "user",
      "content": [
        {
          "type": "input_text",
          "text": "<insert user message>"
        }
      ]
    }
  ],
  "text": {
    "format": {
      "type": "text"
    },
    "verbosity": "low"
  },
  "reasoning": {
    "effort": "medium",
    "summary": null
  },
  "context_management": [
    {
      "type": "compaction",
      "compact_threshold": 300000
    }
  ],
  "tools": [
    {
      "type": "function",
      "name": "shell_call",
      "description": "Run shell cmds in parallel groups.",
      "strict": false,
      "parameters": {
        "type": "object",
        "description": "Tool args.",
        "required": [
          "p"
        ],
        "properties": {
          "c": {
            "type": "string",
            "description": "Default cwd."
          },
          "p": {
            "type": "array",
            "description": "Parallel command groups; use one group only when commands must run in order.",
            "items": {
              "type": "object",
              "description": "Sequential command list.",
              "required": [
                "s"
              ],
              "properties": {
                "c": {
                  "type": "string",
                  "description": "Group cwd."
                },
                "s": {
                  "type": "array",
                  "description": "Run these commands in order.",
                  "items": {
                    "type": "string",
                    "description": "Shell cmd."
                  }
                }
              },
              "additionalProperties": false
            }
          },
          "t": {
            "type": "integer",
            "description": "Timeout ms."
          },
          "l": {
            "type": "integer",
            "description": "Max output chars."
          }
        },
        "additionalProperties": false
      }
    },
    {
      "type": "web_search",
      "user_location": {
        "type": "approximate"
      },
      "search_context_size": "low"
    }
  ],
  "store": true,
  "include": [
    "reasoning.encrypted_content",
    "web_search_call.action.sources"
  ]
}

{
  "model": "gpt-5.4-mini",
  "input": [
    {
      "role": "developer",
      "content": [
        {
          "type": "input_text",
          "text": "<insert AGENTS.md chain>"
        }
      ]
    },
    {
      "role": "user",
      "content": [
        {
          "type": "input_text",
          "text": "<insert user message>"
        }
      ]
    }
  ],
  "text": {
    "format": {
      "type": "text"
    },
    "verbosity": "low"
  },
  "reasoning": {
    "effort": "medium",
    "summary": null
  },
  "context_management": [
    {
      "type": "compaction",
      "compact_threshold": 300000
    }
  ],
  "tools": [
    {
      "type": "function",
      "name": "shell_call",
      "description": "Execute a shell command in a specific working directory.",
      "parameters": {
        "type": "object",
        "required": [
          "command",
          "cwd"
        ],
        "properties": {
          "command": {
            "type": "string",
            "description": "Shell command to execute."
          },
          "cwd": {
            "type": "string",
            "description": "Working directory where the command will be executed."
          }
        },
        "additionalProperties": false
      },
      "strict": true
    },
    {
      "type": "web_search",
      "user_location": {
        "type": "approximate"
      },
      "search_context_size": "low"
    }
  ],
  "store": true,
  "include": []
}

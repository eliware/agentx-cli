{
  "model": "gpt-5.4-mini",
  "input": [
    {
      "role": "developer",
      "content": [
        {
          "type": "input_text",
          "text": "AGENTS.md"
        }
      ]
    },
    {
      "role": "user",
      "content": [
        {
          "type": "input_text",
          "text": "test all 3 functions (parallel tool calls)"
        }
      ]
    }
  ],
  "text": {
    "format": {
      "type": "text"
    },
    "verbosity": "low"
  },
  "reasoning": {
    "effort": "low",
    "summary": "detailed"
  },
  "tools": [
    {
      "type": "function",
      "name": "write_file",
      "description": "Write content to a file at the specified file path",
      "parameters": {
        "type": "object",
        "properties": {
          "file_path": {
            "type": "string",
            "description": "The path where the file will be written"
          },
          "content": {
            "type": "string",
            "description": "The content to write into the file"
          }
        },
        "required": [
          "file_path",
          "content"
        ],
        "additionalProperties": false
      },
      "strict": true
    },
    {
      "type": "function",
      "name": "read_file",
      "description": "Read the contents of a file at the specified file path",
      "parameters": {
        "type": "object",
        "properties": {
          "file_path": {
            "type": "string",
            "description": "Path to the file to be read"
          }
        },
        "required": [
          "file_path"
        ],
        "additionalProperties": false
      },
      "strict": true
    },
    {
      "type": "function",
      "name": "shell_exec",
      "description": "Execute a shell command in a specific working directory.",
      "parameters": {
        "type": "object",
        "required": [
          "command",
          "cwd"
        ],
        "properties": {
          "command": {
            "type": "string",
            "description": "Shell command to execute."
          },
          "cwd": {
            "type": "string",
            "description": "Working directory where the command will be executed."
          }
        },
        "additionalProperties": false
      },
      "strict": true
    },
    {
      "type": "web_search",
      "user_location": {
        "type": "approximate"
      },
      "search_context_size": "low"
    }
  ],
  "store": true,
  "include": [
    "reasoning.encrypted_content",
    "web_search_call.action.sources"
  ]
}

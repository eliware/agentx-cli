{
  "model": "gpt-5.6-luna",
  "input": [
    {
      "role": "developer",
      "content": [
        {
          "type": "input_text",
          "text": "agents.md"
        }
      ]
    },
    {
      "role": "user",
      "content": [
        {
          "type": "input_text",
          "text": "user message"
        }
      ]
    }
  ],
  "text": {
    "format": {
      "type": "text"
    },
    "verbosity": "low"
  },
  "reasoning": {
    "effort": "medium",
    "mode": "standard",
    "summary": null
  },
  "context_management": [
    {
      "type": "compaction",
      "compact_threshold": 200000
    }
  ],
  "tools": [
    {
      "type": "programmatic_tool_calling"
    },
    {
      "type": "web_search",
      "user_location": {
        "type": "approximate"
      },
      "search_context_size": "medium"
    },
    {
      "type": "shell",
      "environment": {
        "type": "local"
      },
      "allowed_callers": [
        "programmatic"
      ]
    }
  ],
  "store": true,
  "include": [
    "reasoning.encrypted_content",
    "web_search_call.action.sources"
  ]
}

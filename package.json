{
    "name": "@eliware/agentx-cli",
    "type": "module",
    "version": "1.3.5",
    "description": "A lightweight terminal chat agent built on the OpenAI Responses API over WebSocket transport.",
    "main": "agentx.mjs",
    "scripts": {
        "start": "node agentx.mjs",
        "lint": "npx oxlint .",
        "test": "npx --node-options=\"--experimental-vm-modules --no-warnings\" jest --coverage --detectOpenHandles --silent --runInBand",
        "setup": "node agentx-setup.mjs"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/eliware/agentx-cli.git"
    },
    "keywords": [
        "agentx",
        "openai",
        "responses-api",
        "cli",
        "terminal",
        "websocket"
    ],
    "author": "Eli Sterling, eliware.org <eli@eliware.org>",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/eliware/agentx-cli/issues"
    },
    "homepage": "https://github.com/eliware/agentx-cli#readme",
    "devDependencies": {
        "jest": "^30.0.4",
        "oxlint": "^1.73.0"
    },
    "jest": {
        "testEnvironment": "node",
        "coveragePathIgnorePatterns": [
            "/src/agent\\.mjs$",
            "/src/completion\\.mjs$",
            "/src/shell\\.mjs$",
            "/src/tool-shell\\.mjs$"
        ],
        "testMatch": [
            "**/?(*.)+(spec|test).[jt]s?(x)",
            "**/?(*.)+(spec|test).mjs",
            "**/?(*.)+(spec|test).cjs"
        ]
    },
    "dependencies": {
        "@eliware/common": "^1.1.4",
        "dotenv": "^17.4.2",
        "string-width": "^8.2.2",
        "strip-ansi": "^7.2.0",
        "ws": "^8.21.0"
    },
    "allowScripts": {
        "unrs-resolver@1.12.2": true
    },
    "bin": {
        "agentx": "./agentx.mjs",
        "agentx-setup": "./agentx-setup.mjs"
    },
    "files": [
        "agentx.mjs",
        "agentx-setup.mjs",
        "prompt.json",
        "src/",
        "docs/",
        ".agentx.example"
    ]
}